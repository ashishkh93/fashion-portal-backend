{
  "version": 2,
  "functions": {
    "api/test.js": {
      "maxDuration": 30
    },
    "api/*.js": {
      "maxDuration": 15
    },
    "src/api/*.js": {
      "maxDuration": 25
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/src/app.js" },
    { "src": "/(.*)", "dest": "/src/app.js" }
  ]
}
